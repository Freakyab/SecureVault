// ── Helpers ───────────────────────────────────────────────────────────────────

const PRIORITY_MAP = { P0: 'Highest', P1: 'High', P2: 'Medium', P3: 'Low' };

function getCredentials() {
  const fs = require('fs');
  const path = require('path');
  const configPath = path.join(process.env.APPDATA, 'Code', 'User', 'globalStorage', 'saoudrizwan.claude-dev', 'settings', 'cline_mcp_settings.json');
  const raw = fs.readFileSync(configPath, 'utf-8');
  const config = JSON.parse(raw);
  const server = config.mcpServers?.['github.com/pashpashpash/mcp-atlassian'];
  if (!server) throw new Error('Atlassian MCP server not found');
  return { jiraUrl: server.env.JIRA_URL, email: server.env.JIRA_USERNAME, token: server.env.JIRA_API_TOKEN };
}

function basicAuth(email, token) {
  return 'Basic ' + Buffer.from(email + ':' + token).toString('base64');
}

function toAdf(text) {
  const lines = text.split('\n').filter(l => l.trim());
  const content = lines.map(line => {
    if (line.startsWith('h3. ')) return { type: 'paragraph', content: [{ type: 'text', text: line.slice(4), marks: [{ type: 'strong' }] }] };
    return { type: 'paragraph', content: [{ type: 'text', text: line }] };
  });
  return { type: 'doc', version: 1, content };
}

