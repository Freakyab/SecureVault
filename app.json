{
  "expo": {
    "name": "SecureVault",
    "slug": "securevault",
    "description": "SecureVault is an offline-first password manager: store credentials, generate strong passwords, and monitor password health locally on your device.",
    "primaryColor": "#2D6CF6",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "securevault",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.securevault.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PlayfairDisplay_500Medium.ttf",
            "./assets/fonts/PlayfairDisplay_600SemiBold.ttf",
            "./assets/fonts/PlayfairDisplay_700Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1020",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aeb65b93-d8cd-4ab9-93a3-4343b8ebcf9e"
      }
    }
  }
}
